---
import '@/styles/global.css'

import { ClientRouter } from 'astro:transitions'

import HeadSeo from '@/layouts/HeadSeo.astro'

import Footer from '@/components/layout/footer'
import HeaderSection from '@/components/sections/header-section'

interface Props {
  title?: string
  description?: string
  image?: string
  type?: 'website' | 'article'
  keywords?: string
  author?: string
  publishedTime?: string
  modifiedTime?: string
  noindex?: boolean
  nofollow?: boolean
  schema?: Record<string, any>
}

const seoProps = Astro.props as Props
---

<!doctype html>
<html lang='en' class='scroll-smooth'>
  <head>
    <HeadSeo {...seoProps} />
    <ClientRouter />

    <style>
      /* Disable all view transitions while keeping client-side navigation */
      ::view-transition-group(*),
      ::view-transition-old(*),
      ::view-transition-new(*) {
        animation-duration: 0ms !important;
      }
    </style>
  </head>
  <body class='flex min-h-full w-full flex-auto flex-col'>
    <noscript>
      <div
        style='padding:1.5rem;font-family:system-ui,sans-serif;background:#030712;color:#f9fafb;'
      >
        <p><strong>JavaScript ist deaktiviert oder blockiert.</strong></p>
        <p>Diese Vorlage braucht JavaScript für die Inhalte. Bitte JS aktivieren oder die Seite in den Entwicklertools prüfen (Konsole / Netzwerk, z. B. fehlende <code>/_astro/*.js</code>).</p>
      </div>
    </noscript>
    <div class='flex flex-col'>
      <HeaderSection client:load />

      <main class='flex flex-col overflow-hidden **:scroll-mt-25'><slot /></main>

      <Footer client:load />
    </div>
  </body>
</html>

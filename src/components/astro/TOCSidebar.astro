---
type Props = {
  headings: { slug: string; text: string; depth: number }[]
}

const { headings } = Astro.props

// Build hierarchical tree structure for headings
interface TocItem {
  slug: string
  text: string
  depth: number
  children: TocItem[]
}

function buildTocTree(headings: { slug: string; text: string; depth: number }[]): TocItem[] {
  const root: TocItem[] = []
  const stack: TocItem[] = []

  headings.forEach(heading => {
    const item: TocItem = {
      slug: heading.slug,
      text: heading.text,
      depth: heading.depth,
      children: []
    }

    // Find the appropriate parent
    while (stack.length > 0 && stack[stack.length - 1].depth >= heading.depth) {
      stack.pop()
    }

    // Add to parent's children or root
    if (stack.length === 0) {
      root.push(item)
    } else {
      stack[stack.length - 1].children.push(item)
    }

    stack.push(item)
  })

  return root
}

const groupedHeadings = buildTocTree(headings)
---

{
  groupedHeadings.length > 0 && (
    <div class='bg-card sticky top-20 hidden rounded-lg border px-3 py-6 shadow-2xl md:block'>
      <div class='mb-5 text-xl font-medium'>Contents</div>
      <nav>
        <ul class='flex list-none flex-col gap-6'>
          {groupedHeadings.map((item, index) => (
            <li class='relative flex items-start gap-3'>
              {/* Vertical line */}
              {index < groupedHeadings.length - 1 && (
                <div class='bg-border absolute top-3 left-2.25 h-[calc(100%+1.5rem)] w-px' aria-hidden='true' />
              )}

              {/* Dot */}
              <div class='bg-secondary/20 toc-dot relative z-10 mt-1.5 flex size-4.5 shrink-0 items-center justify-center rounded-full'>
                <span
                  class='bg-secondary toc-dot-inner block size-2.5 rounded-full transition-all duration-200'
                  aria-hidden='true'
                />
              </div>

              {/* Link */}
              <a
                href={`#${item.slug}`}
                class='text-foreground toc-link flex-1 py-1 text-sm opacity-70 transition-colors duration-200 hover:opacity-100'
                data-heading-link={item.slug}
              >
                {item.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  )
}

<script>
  const HEADER_OFFSET = 150

  function highlightActiveHeading() {
    const headings = Array.from(document.querySelectorAll<HTMLElement>('.prose h2[id]'))

    if (headings.length === 0) return

    const scrollY = window.scrollY || window.pageYOffset
    let activeId = ''

    // Find the last heading above the scroll position
    for (let i = headings.length - 1; i >= 0; i--) {
      const heading = headings[i]
      const headingTop = heading.getBoundingClientRect().top + scrollY
      if (headingTop - HEADER_OFFSET <= scrollY) {
        activeId = heading.id
        break
      }
    }

    // If no heading is found, default to the first one
    if (!activeId && headings.length > 0) {
      activeId = headings[0].id
    }

    // Update all links
    const links = document.querySelectorAll('[data-heading-link]')
    links.forEach(link => {
      const linkId = link.getAttribute('data-heading-link')
      const dot = link.closest('li')?.querySelector('.toc-dot')
      const dotInner = link.closest('li')?.querySelector('.toc-dot-inner')

      if (linkId === activeId) {
        // Active state
        link.classList.remove('opacity-70')
        link.classList.add('opacity-100')
        dot?.classList.remove('bg-secondary/20')
        dot?.classList.add('bg-primary/20')
        dotInner?.classList.remove('bg-secondary')
        dotInner?.classList.add('bg-primary')
      } else {
        // Inactive state
        link.classList.remove('opacity-100')
        link.classList.add('opacity-70')
        dot?.classList.remove('bg-primary/20')
        dot?.classList.add('bg-secondary/20')
        dotInner?.classList.remove('bg-primary')
        dotInner?.classList.add('bg-secondary')
      }
    })
  }

  // Smooth scroll behavior
  function setupSmoothScroll() {
    const links = document.querySelectorAll('.toc-link')

    links.forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault()
        const href = link.getAttribute('href')
        if (href) {
          const target = document.querySelector(href)
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' })
            setTimeout(() => highlightActiveHeading(), 100)
          }
        }
      })
    })
  }

  document.addEventListener('astro:page-load', () => {
    highlightActiveHeading()
    setupSmoothScroll()
    window.addEventListener('scroll', highlightActiveHeading, { passive: true })
  })

  document.addEventListener('astro:before-swap', () => {
    window.removeEventListener('scroll', highlightActiveHeading)
  })
</script>

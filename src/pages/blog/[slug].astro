---
import Layout from '@/layouts/Layout.astro'
import TOCSidebar from '@/components/astro/TOCSidebar.astro'
import BlogCTASection from '@/components/sections/blog-cta-section'
import FooterSection from '@/components/sections/footer-section'
import RelatedBlogSection from '@/components/blog/related-blog-section'
import { AuthorMetadata } from '@/components/blog/AuthorAvatar'
import AISummaryButtons from '@/components/blog/ai-summary-buttons'

import { SecondaryOrionButton } from '@/components/ui/orion-button'
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator
} from '@/components/ui/breadcrumb'
import { getAllPosts, getAdjacentPosts, getTOCHeadings, calculateReadTime, getRelatedPosts } from '@/lib/data-utils'

import { render } from 'astro:content'
import { ChevronLeftIcon, ChevronRightIcon } from 'lucide-react'

export async function getStaticPaths() {
  const posts = await getAllPosts()
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: post
  }))
}

const post = Astro.props
const currentPostId = post.data.slug

// Render post content
const { Content } = await render(post)

// Get navigation and TOC
const navigation = await getAdjacentPosts(currentPostId)
const tocHeadings = await getTOCHeadings(currentPostId)

// Calculate read time dynamically from post body
const postContent = post.body || ''
const readTime = calculateReadTime(postContent)

// Build full post URL for AI summary
const postUrl = `${Astro.site}blog/${post.data.slug}/`

// Get related posts
const relatedPostsData = await getRelatedPosts(currentPostId, post.data.category)
const relatedPosts = relatedPostsData.map(p => ({
  slug: p.data.slug,
  title: p.data.title,
  description: p.data.description,
  image: p.data.imageUrl || '/images/placeholder.jpg',
  category: p.data.category,
  readTime: `${calculateReadTime(p.body || '')} min`,
  author: {
    name: p.data.author,
    picture: p.data.avatarUrl || '/images/avatar-placeholder.jpg'
  }
}))

// Comprehensive Schema.org structured data
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    // BlogPosting schema
    {
      '@type': 'BlogPosting',
      '@id': `${Astro.site}blog/${post.data.slug}/#article`,
      headline: post.data.title,
      description: post.data.description,
      image: {
        '@type': 'ImageObject',
        url: post.data.imageUrl ? new URL(post.data.imageUrl, Astro.site).toString() : undefined,
        width: 1200,
        height: 630
      },
      datePublished: post.data.pubDate,
      dateModified: post.data.pubDate,
      author: {
        '@type': 'Person',
        name: post.data.author
      },
      publisher: {
        '@type': 'Organization',
        name: 'Shadcn Studio',
        logo: {
          '@type': 'ImageObject',
          url: new URL('/images/site-logo.png', Astro.site).toString()
        }
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': `${Astro.site}blog/${post.data.slug}/`
      },
      keywords: post.data.tags?.join(', '),
      articleSection: post.data.category,
      inLanguage: 'en-US',
      isPartOf: {
        '@type': 'Blog',
        '@id': `${Astro.site}blog/#blog`,
        name: 'Shadcn Studio Blog'
      },
      wordCount: postContent.trim().split(/\s+/).length,
      timeRequired: `PT${readTime}M`
    },

    // BreadcrumbList schema
    {
      '@type': 'BreadcrumbList',
      '@id': `${Astro.site}blog/${post.data.slug}/#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: Astro.site?.toString() || ''
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: `${Astro.site}blog/`
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: post.data.title,
          item: `${Astro.site}blog/${post.data.slug}/`
        }
      ]
    },

    // WebPage schema
    {
      '@type': 'WebPage',
      '@id': `${Astro.site}blog/${post.data.slug}/#webpage`,
      url: `${Astro.site}blog/${post.data.slug}/`,
      name: post.data.title,
      description: post.data.description,
      datePublished: post.data.pubDate,
      dateModified: post.data.pubDate,
      inLanguage: 'en-US',
      isPartOf: {
        '@type': 'WebSite',
        '@id': `${Astro.site}#website`
      },
      breadcrumb: {
        '@id': `${Astro.site}blog/${post.data.slug}/#breadcrumb`
      },
      primaryImageOfPage: {
        '@id': `${Astro.site}blog/${post.data.slug}/#primaryimage`
      }
    }
  ]
}
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.imageUrl}
  type='article'
  publishedTime={post.data.pubDate}
  author={post.data.author}
  schema={schema}
  keywords={post.data.tags?.join(', ')}
>
  <section class='relative -mt-15.75 flex flex-col pt-15.75'>
    <div class='px-4 sm:px-6 lg:px-8'>
      <div class='mx-auto w-full max-w-7xl border-x'>
        <div class='grid grid-cols-1 lg:grid-cols-[340px_1fr] xl:grid-cols-[400px_1fr]'>
          <!-- Left Sidebar - TOC -->
          <aside class='bg-muted hidden px-4 py-8 sm:py-16 md:px-5 lg:block lg:py-24'>
            <TOCSidebar headings={tocHeadings} />
          </aside>

          <!-- Main Content -->
          <article class='space-y-8 px-4 py-8 sm:py-16 md:space-y-12 md:px-6 lg:space-y-16 lg:px-8 lg:py-24'>
            <div class='space-y-6'>
              <!-- Breadcrumb -->
              <Breadcrumb className='mb-6' client:load>
                <BreadcrumbList>
                  <BreadcrumbItem>
                    <BreadcrumbLink href='/'>Home</BreadcrumbLink>
                  </BreadcrumbItem>
                  <BreadcrumbSeparator />
                  <BreadcrumbItem>
                    <BreadcrumbLink href='/blog'>Blog</BreadcrumbLink>
                  </BreadcrumbItem>
                  <BreadcrumbSeparator />
                  <BreadcrumbItem>
                    <BreadcrumbPage className='text-foreground'>{post.data.title}</BreadcrumbPage>
                  </BreadcrumbItem>
                </BreadcrumbList>
              </Breadcrumb>

              <!-- Title -->
              <h1 class='text-2xl font-semibold tracking-tight sm:text-3xl lg:text-4xl'>{post.data.title}</h1>

              <!-- Author & Read Time -->
              <div class='flex flex-wrap items-center justify-between gap-6'>
                <div class='flex items-center gap-2'>
                  <AuthorMetadata client:load avatarUrl={post.data.avatarUrl} author={post.data.author} />
                  <div class='flex flex-col gap-1'>
                    <span class='text-muted-foreground text-sm'>Written by</span>
                    <span class='text-sm font-medium'>{post.data.author}</span>
                  </div>
                </div>
                <div class='flex flex-col'>
                  <span class='text-muted-foreground text-xs'>Read time</span>
                  <span class='text-sm font-medium'>{readTime} min</span>
                </div>
              </div>
            </div>

            <!-- Hero Image -->
            {
              post.data.imageUrl && (
                <div class='overflow-hidden rounded-lg'>
                  <img src={post.data.imageUrl} alt={post.data.title} class='w-full object-cover' />
                </div>
              )
            }

            <!-- AI Summary Buttons -->
            <AISummaryButtons postTitle={post.data.title} postUrl={postUrl} client:load />

            <!-- MDX Content -->
            <div class='prose dark:prose-invert prose-neutral max-w-none space-y-4'>
              <Content />
            </div>

            <!-- Navigation -->
            <div class='mt-8 flex items-center justify-between gap-4 md:mt-12 lg:mt-16'>
              {
                navigation.older ? (
                  <a href={`/blog/${navigation.older.data.slug}`}>
                    <SecondaryOrionButton size='lg' client:load>
                      <ChevronLeftIcon className='size-4' />
                      <span>Previous post</span>
                    </SecondaryOrionButton>
                  </a>
                ) : (
                  <SecondaryOrionButton size='lg' disabled client:load>
                    <ChevronLeftIcon className='size-4' />
                    <span>Previous post</span>
                  </SecondaryOrionButton>
                )
              }

              {
                navigation.newer ? (
                  <a href={`/blog/${navigation.newer.data.slug}`}>
                    <SecondaryOrionButton size='lg' client:load>
                      <span>Next post</span>
                      <ChevronRightIcon className='size-4' />
                    </SecondaryOrionButton>
                  </a>
                ) : (
                  <SecondaryOrionButton size='lg' disabled client:load>
                    <span>Next post</span>
                    <ChevronRightIcon className='size-4' />
                  </SecondaryOrionButton>
                )
              }
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Blog Section -->
  <RelatedBlogSection posts={relatedPosts} client:load />

  <!-- CTA Section -->
  <BlogCTASection client:load />

  <!-- Footer -->
  <FooterSection newsletter={false} client:load />

  <script>
    // KaTeX support
    if (document.querySelector('.katex')) {
      if (!document.querySelector('link[href*="katex.min.css"]')) {
        const link = document.createElement('link')
        link.rel = 'stylesheet'
        link.href = 'https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css'
        document.head.appendChild(link)
      }
    }

    // Code block copy button functionality
    function addCopyButtons() {
      const codeBlocks = document.querySelectorAll<HTMLPreElement>('.prose pre')

      codeBlocks.forEach((pre: HTMLPreElement) => {
        // Skip if button already exists
        if (pre.querySelector('.copy-button')) return

        const button = document.createElement('button')
        button.className =
          "copy-button focus-visible:border-ring focus-visible:ring-ring/50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive inline-flex shrink-0 items-center justify-center text-sm font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px] disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 gap-1.5 px-3 has-[>svg]:px-2.5 bg-primary/10 text-primary hover:bg-primary/90 hover:text-primary-foreground absolute top-2 right-4 h-5 rounded-full"
        button.innerHTML = `
          <svg class="copy-icon size-3.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
          <span class="copy-text">Copy</span>
          <svg class="check-icon size-3.5 hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          <span class="copied-text hidden">Copied</span>
        `

        button.addEventListener('click', async () => {
          const code = pre.querySelector('code')
          if (!code) return

          const text = code.textContent || ''
          await navigator.clipboard.writeText(text)

          // Show copied state
          button.querySelector('.copy-icon')?.classList.add('hidden')
          button.querySelector('.copy-text')?.classList.add('hidden')
          button.querySelector('.check-icon')?.classList.remove('hidden')
          button.querySelector('.copied-text')?.classList.remove('hidden')

          // Reset after 2 seconds
          setTimeout(() => {
            button.querySelector('.copy-icon')?.classList.remove('hidden')
            button.querySelector('.copy-text')?.classList.remove('hidden')
            button.querySelector('.check-icon')?.classList.add('hidden')
            button.querySelector('.copied-text')?.classList.add('hidden')
          }, 2000)
        })

        pre.style.position = 'relative'
        pre.appendChild(button)
      })
    }

    // Run on page load
    document.addEventListener('astro:page-load', addCopyButtons)
  </script>
</Layout>

---
import Layout from '@/layouts/Layout.astro'
import { getAllPosts, getFeaturedPosts, calculateReadTime } from '@/lib/data-utils'
import BlogSection from '@/components/blog/blog-section/blog-section'
import BlogCTASection from '@/components/sections/blog-cta-section'
import FooterSection from '@/components/sections/footer-section'
import { Badge } from '@/components/ui/badge'
import { BorderBeam } from '@/components/ui/border-beam'
import { MotionPreset } from '@/components/ui/motion-preset'

// Get all blog posts and featured posts
const allPosts = await getAllPosts()
const featuredPostsData = await getFeaturedPosts()

// Transform posts to match the BlogPostMetadata type
const blogData = allPosts.map(post => ({
  slug: post.data.slug,
  title: post.data.title,
  description: post.data.description,
  image: post.data.imageUrl || '/images/placeholder.jpg',
  publishedAt: post.data.pubDate,
  author: {
    name: post.data.author,
    picture: post.data.avatarUrl || '/images/avatar-placeholder.jpg'
  },
  category: post.data.category,
  readTime: `${calculateReadTime(post.body || '')} min`,
  featured: post.data.featured
}))

const featuredPosts = featuredPostsData.map(post => ({
  slug: post.data.slug,
  title: post.data.title,
  description: post.data.description,
  image: post.data.imageUrl || '/images/placeholder.jpg',
  publishedAt: post.data.pubDate,
  author: {
    name: post.data.author,
    picture: post.data.avatarUrl || '/images/avatar-placeholder.jpg'
  },
  category: post.data.category,
  readTime: `${calculateReadTime(post.body || '')} min`,
  featured: post.data.featured
}))

const pageTitle = 'Blog'
const pageDescription = 'Welcome to our blog. Stay updated with the latest news and articles.'

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      name: 'Template Name',
      description: 'Template Description',
      url: `${Astro.site}`,
      inLanguage: 'en-US'
    },
    {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      '@id': `${Astro.site}#webpage`,
      name: 'Blog',
      description: 'Welcome to our blog. Stay updated with the latest news and articles.',
      url: `${Astro.site}blog`,
      isPartOf: {
        '@id': `${Astro.site}#website`
      },
      potentialAction: {
        '@type': 'ReadAction',
        target: [`${Astro.site}blog`]
      }
    }
  ]
}
---

<Layout title={pageTitle} description={pageDescription} schema={schema}>
  <!-- Hero -->
  <section id='home' class='relative -mt-15.75 flex flex-col overflow-hidden pt-15.75'>
    <div class='px-4 sm:px-6 lg:px-8'>
      <div class='mx-auto flex max-w-7xl flex-col gap-6 border-x px-4 py-8 sm:px-6 sm:py-16 lg:px-8 lg:py-24'>
        <div class='flex flex-col items-center gap-6 text-center'>
          <MotionPreset fade blur transition={{ duration: 0.5 }} client:load>
            <Badge variant='outline' className='bg-muted relative mb-4 gap-2.5 px-1.5 py-1'>
              <span class='bg-primary text-primary-foreground flex h-5.5 items-center rounded-full px-2 py-0.5'>
                Insights
              </span>
              <span class='text-muted-foreground text-sm font-normal text-wrap'>AI agent</span>
              <BorderBeam colorFrom='var(--primary)' colorTo='var(--primary)' size={35} client:load />
            </Badge>

            <h1 class='mb-4 text-2xl font-semibold sm:text-3xl lg:text-5xl lg:leading-[1.29167]'>
              Resources for Automating Work with AI Agents
            </h1>

            <p class='text-muted-foreground mx-auto max-w-3xl text-xl'>
              Practical articles, guides, and insights to help you design smarter workflows, connect your tools, and
              scale daily operations with AI.
            </p>
          </MotionPreset>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Section -->
  <BlogSection posts={blogData} featuredPosts={featuredPosts} client:load />

  <!-- CTA Section -->
  <BlogCTASection client:load />

  <!-- Footer -->
  <FooterSection newsletter={false} client:load />
</Layout>

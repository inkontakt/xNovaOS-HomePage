---
import BlankLayout from '@/layouts/BlankLayout.astro'

const description =
  'xNovaOS – die öffentliche Startseite ist in Arbeit. Wir melden uns, sobald es mehr zu zeigen gibt.'
const keywords = 'xNovaOS, coming soon, operating system'

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'xNovaOS',
  url: Astro.site?.toString(),
  description
}
---

<BlankLayout
  lang='de'
  pageTitle='xNovaOS – Demnächst'
  description={description}
  keywords={keywords}
  schema={schema}
>
  <section
    class='relative flex min-h-[100dvh] flex-col items-center justify-center overflow-hidden bg-gray-950 px-6 py-20'
  >
    <div
      class='pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(56,189,248,0.22),transparent)]'
    >
    </div>
    <div
      class='pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_100%_50%,rgba(99,102,241,0.12),transparent)]'
    >
    </div>

    <div class='relative z-10 max-w-lg text-center'>
      <p class='text-sm font-medium tracking-[0.25em] text-sky-400/90 uppercase'>xNovaOS</p>
      <h1 class='mt-5 text-4xl font-semibold tracking-tight text-white sm:text-5xl'>Demnächst</h1>
      <p class='mt-6 text-lg leading-relaxed text-white/65'>
        Wir bauen gerade an dieser Seite. Schau später wieder vorbei – oder nutze vorerst die
        vollständige Template-Demo.
      </p>
      <p class='mt-8'>
        <a
          href='/landing/'
          class='inline-flex items-center justify-center rounded-full border border-white/15 bg-white/5 px-5 py-2.5 text-sm font-medium text-white/90 transition hover:border-sky-500/40 hover:bg-sky-500/10 hover:text-white'
        >
          Template-Demo ansehen
        </a>
      </p>
    </div>
  </section>
</BlankLayout>

---
import Layout from '@/layouts/Layout.astro'
import HeroSection from '@/components/sections/hero-section'
import FeaturesSection from '@/components/sections/features-section'
import WorksFeaturesSectionPage from '@/components/sections/works-features-section'
import UseCasesSection from '@/components/sections/use-cases-section'
import TestimonialsSection from '@/components/sections/testimonials-section'
import PricingSectionPage from '@/components/sections/pricing-section'
import FAQSectionPage from '@/components/sections/faq-section'
import CTASection from '@/components/sections/cta-section'
import FooterSection from '@/components/sections/footer-section'

// Page-specific SEO configuration
const pageTitle = ''
const pageDescription =
  'Automate routine tasks, connect your tools, and let your AI agent coordinate workflows so you can focus on strategy, not busywork. Boost productivity with intelligent automation.'
const pageKeywords =
  'AI agent, workflow automation, task automation, productivity tools, AI productivity, workflow management, business automation, AI assistant, smart automation, team productivity, AI workflow, automation platform, intelligent agent, work automation, productivity automation'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': `${Astro.site}#website`,
      name: 'Orion',
      description: pageDescription,
      url: `${Astro.site}`,
      inLanguage: 'en-US'
    }
  ]
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  <HeroSection client:load />
  <FeaturesSection client:load />
  <WorksFeaturesSectionPage client:load />
  <UseCasesSection client:load />
  <TestimonialsSection client:load />
  <PricingSectionPage client:load />
  <FAQSectionPage client:load />
  <CTASection client:load />
  <FooterSection newsletter={true} client:load />
</Layout>

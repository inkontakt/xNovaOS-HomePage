---
import BlankLayout from '@/layouts/BlankLayout.astro'
import ForgotPasswordPage from '@/components/sections/forgot-password-section'

// Page-specific SEO configuration
const pageTitle = 'Forgot Password - Reset Your Password | Orion'
const pageDescription =
  "Reset your password to regain access to your account. We'll send you secure instructions to create a new password."
---

<BlankLayout title={pageTitle} description={pageDescription} noindex nofollow>
  <ForgotPasswordPage client:load />
</BlankLayout>

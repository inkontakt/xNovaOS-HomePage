---
import Layout from '@/layouts/Layout.astro'
import { Badge } from '@/components/ui/badge'
import { BorderBeam } from '@/components/ui/border-beam'
import { MotionPreset } from '@/components/ui/motion-preset'

import IntegrationToolsSection from '@/components/sections/app-integration-section'
import UseCasesSection from '@/components/sections/use-cases-section'
import AppIntegrationCTASection from '@/components/sections/app-integration-cta-section'
import FooterSection from '@/components/sections/footer-section'

// Page-specific SEO configuration
const pageTitle = 'App Integration'
const pageDescription =
  'Discover how to seamlessly integrate AI agents into your applications and workflows. Explore practical guides, best practices, and real-world examples to connect your tools, automate tasks, and enhance productivity with AI.'
const pageKeywords = 'app integration, automation, workflow, tools'

// Structured data for better SEO
const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'App Integration',
  description: pageDescription,
  url: `${Astro.site}app-integration`
}
---

<Layout title={pageTitle} description={pageDescription} keywords={pageKeywords} schema={schema}>
  {/* Hero */}
  <section id='home' class='relative -mt-15.75 flex flex-col overflow-hidden pt-15.75'>
    <div class='px-4 sm:px-6 lg:px-8'>
      <div class='mx-auto flex max-w-7xl flex-col gap-6 border-x px-4 py-8 sm:px-6 sm:py-16 lg:px-8 lg:py-24'>
        <div class='flex flex-col items-center gap-6 text-center'>
          <MotionPreset fade blur transition={{ duration: 0.5 }} client:load>
            <Badge variant='outline' className='bg-muted relative mb-4 gap-2.5 px-1.5 py-1'>
              <span class='bg-primary text-primary-foreground flex h-5.5 items-center rounded-full px-2 py-0.5'>
                Integrations
              </span>
              <span class='text-muted-foreground text-sm font-normal text-wrap'>with available tools</span>
              <BorderBeam colorFrom='var(--primary)' colorTo='var(--primary)' size={35} client:load />
            </Badge>

            <h1 class='mb-4 text-2xl font-semibold sm:text-3xl lg:text-5xl lg:leading-[1.29167]'>
              Integrations That Power Your Workflow
            </h1>

            <p class='text-muted-foreground mx-auto max-w-3xl text-xl'>
              Seamlessly connect Orion with the tools your team already uses to keep workflows running smoothly and
              efficiently.
            </p>
          </MotionPreset>
        </div>
      </div>
    </div>
  </section>

  {/* Integration Tools Section */}
  <IntegrationToolsSection client:load />

  {/* Use Cases Section */}
  <UseCasesSection client:load />

  {/* CTA Section */}
  <AppIntegrationCTASection client:load />

  {/* Footer */}
  <FooterSection newsletter={true} client:load />
</Layout>
